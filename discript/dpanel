#!/usr/bin/env bash
set -euo pipefail

panel_repo_root() {
  local candidate=""
  local current=""

  if [[ -n "${LIKESOFT_REPOSITORY_DIR:-}" && -f "${LIKESOFT_REPOSITORY_DIR}/bootstrap/core.sh" ]]; then
    printf '%s' "${LIKESOFT_REPOSITORY_DIR}"
    return 0
  fi

  candidate="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
  if [[ -f "${candidate}/bootstrap/core.sh" ]]; then
    printf '%s' "$candidate"
    return 0
  fi

  current="${PWD}"
  while [[ "$current" != "/" ]]; do
    if [[ -f "${current}/bootstrap/core.sh" ]]; then
      printf '%s' "$current"
      return 0
    fi
    current="$(dirname "$current")"
  done

  printf '%s' "$candidate"
}

REPO_ROOT="$(panel_repo_root)"

export LIKESOFT_REPOSITORY_DIR="${LIKESOFT_REPOSITORY_DIR:-${REPO_ROOT}}"
export LIKESOFT_BASE_DIR="${LIKESOFT_BASE_DIR:-${REPO_ROOT}/.dpanel}"
export LIKESOFT_RUNTIME_DIR="${LIKESOFT_RUNTIME_DIR:-${LIKESOFT_BASE_DIR}/runtime}"
export LIKESOFT_CACHE_DIR="${LIKESOFT_CACHE_DIR:-${LIKESOFT_BASE_DIR}/cache}"
export LIKESOFT_MODULE_DIR="${LIKESOFT_MODULE_DIR:-${LIKESOFT_BASE_DIR}/modules}"
export LIKESOFT_LOG_DIR="${LIKESOFT_LOG_DIR:-${LIKESOFT_BASE_DIR}/logs}"
export LIKESOFT_TEMPLATE_DIR="${LIKESOFT_TEMPLATE_DIR:-${LIKESOFT_BASE_DIR}/templates}"
export LIKESOFT_MANIFEST_DIR="${LIKESOFT_MANIFEST_DIR:-${LIKESOFT_BASE_DIR}/manifests}"
export LIKESOFT_LAUNCHER="${LIKESOFT_LAUNCHER:-${LIKESOFT_BASE_DIR}/bin/panel}"
export LIKESOFT_DUAL_LAUNCHER="${LIKESOFT_DUAL_LAUNCHER:-${LIKESOFT_BASE_DIR}/bin/dpanel}"
export LIKESOFT_DOWNLOADED_CORE="${LIKESOFT_DOWNLOADED_CORE:-${REPO_ROOT}/bootstrap/core.sh}"
export LIKESOFT_DOWNLOADED_PACKAGE_MANAGER="${LIKESOFT_DOWNLOADED_PACKAGE_MANAGER:-${REPO_ROOT}/core/package-manager.sh}"

mkdir -p "${LIKESOFT_BASE_DIR}/bin"
mkdir -p "${LIKESOFT_BASE_DIR}/cache" "${LIKESOFT_BASE_DIR}/logs" "${LIKESOFT_BASE_DIR}/modules" "${LIKESOFT_BASE_DIR}/templates" "${LIKESOFT_BASE_DIR}/manifests" "${LIKESOFT_BASE_DIR}/runtime"

# shellcheck disable=SC1091
source "${REPO_ROOT}/bootstrap/core.sh"
# shellcheck disable=SC1091
source "${REPO_ROOT}/core/package-manager.sh"

if [[ ! -f "${LIKESOFT_RUNTIME_DIR}/core.sh" || ! -f "${LIKESOFT_RUNTIME_DIR}/package-manager.sh" ]]; then
  panel_install_runtime_assets
fi

panel_cli_dispatch "$@"
